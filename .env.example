# SoSoValue market intelligence (optional — demo mode works without it)
SOSOVALUE_API_KEY=

# SoDEX testnet prepare + signed submit
# Preferred long-term: create a key at https://sodex.com/apikeys
# Quick testnet demo: master-wallet signing
#   SODEX_TESTNET_SIGN_MODE=master
# API-key mode:
#   SODEX_TESTNET_SIGN_MODE=api_key
#   SODEX_TESTNET_API_KEY=<exact key name>
#   SODEX_TESTNET_PRIVATE_KEY=<API key private key, not always master>
SODEX_TESTNET_SUBMIT_ENABLED=false
SODEX_TESTNET_SIGN_MODE=master
SODEX_TESTNET_BASE_URL=https://testnet-gw.sodex.dev/api/v1/perps
SODEX_TESTNET_SUBMIT_URL=https://testnet-gw.sodex.dev/api/v1/perps/trade/orders
SODEX_TESTNET_CHAIN_ID=138565
# API key *name* (X-API-Key). Leave empty for master mode.
SODEX_TESTNET_API_KEY=
# Private key for EIP-712 signatures
SODEX_TESTNET_PRIVATE_KEY=
# Numeric account ID (aid) from /accounts/{address}/state
SODEX_TESTNET_ACCOUNT_ID=
# Optional master address if ACCOUNT_ID empty
SODEX_TESTNET_MASTER_ADDRESS=
